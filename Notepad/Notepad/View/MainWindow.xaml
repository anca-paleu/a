<Window x:Class="Notepad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Notepad.ViewModels"
        xmlns:local="clr-namespace:Notepad.View"
        mc:Ignorable="d"
        Title="Notepad" Height="600" Width="1000">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:InverseBoolConverter x:Key="InverseBool" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="0" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Menu Grid.Row="0" Grid.ColumnSpan="3">
            <MenuItem Header="File">
                <MenuItem Header="New file" Command="{Binding NewFileCommand}" />
                <MenuItem Header="Open file..." Command="{Binding OpenFileCommand}" />
                <MenuItem Header="Save file" Command="{Binding SaveCommand}" />
                <MenuItem Header="Save file as..." Command="{Binding SaveAsCommand}" />
                <MenuItem Header="Close file" Command="{Binding CloseFileCommand}" />
                <MenuItem Header="Close all files" Command="{Binding CloseAllFilesCommand}" />
                <Separator />
                <MenuItem Header="Exit" Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="Search">
                <MenuItem Header="All tabs"      IsCheckable="True" IsChecked="{Binding SearchAllTabs}" />
                <MenuItem Header="Selected tab"  IsCheckable="True" IsChecked="{Binding SearchAllTabs, Converter={StaticResource InverseBool}}" />
                <Separator/>
                <MenuItem Header="Find..." Command="{Binding FindCommand}"/>
                <MenuItem Header="Find Next" Command="{Binding FindNextCommand}"/>
                <MenuItem Header="Find Previous" Command="{Binding FindPreviousCommand}"/>
                <MenuItem Header="Replace..." Command="{Binding ReplaceCommand}" />
                <MenuItem Header="Replace All..." Command="{Binding ReplaceAllCommand}" />
            </MenuItem>
            <MenuItem Header="View">
                <MenuItem Header="Standard" Command="{Binding ViewStandardCommand}" />
                <MenuItem Header="Folder Explorer" Command="{Binding ViewFolderExplorerCommand}" />
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="About" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>

        <ToolBarTray Grid.Row="1" Grid.ColumnSpan="3">
            <ToolBar>
                <Button Content="New" Command="{Binding NewFileCommand}" />
                <Button Content="Open" Command="{Binding OpenFileCommand}" />
                <Button Content="Close" Command="{Binding CloseFileCommand}" />
                <Button Content="Save" Command="{Binding SaveCommand}" />
                <TextBlock Text="Search:" VerticalAlignment="Center" Margin="5,0"/>
                <TextBox Width="150" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="3,0"/>
                <TextBlock Text="Replace:" VerticalAlignment="Center" Margin="5,0"/>
                <TextBox Width="150" Text="{Binding ReplaceText, UpdateSourceTrigger=PropertyChanged}" Margin="3,0"/>
                <CheckBox Content="All tabs" IsChecked="{Binding SearchAllTabs}" VerticalAlignment="Center" Margin="5,0"/>
                <Button Content="Find"        Command="{Binding FindCommand}"       Margin="3,0"/>
                <Button Content="Replace"     Command="{Binding ReplaceCommand}"    Margin="3,0"/>
                <Button Content="Replace All" Command="{Binding ReplaceAllCommand}" Margin="3,0"/>
            </ToolBar>
        </ToolBarTray>

        <TreeView Grid.Row="2" Grid.Column="0" 
                  HorizontalAlignment="Stretch"
                  MinWidth="150"
                  ScrollViewer.HorizontalScrollBarVisibility="Visible" 
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  Visibility="{Binding IsFolderExplorerVisible, Converter={StaticResource BoolToVis}}"
                  ItemsSource="{Binding Directories}"
                  BorderThickness="0">

            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <TextBlock Text="{Binding Name}" TextWrapping="NoWrap" Background="Transparent"
               Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}">

                        <TextBlock.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick" 
                          Command="{Binding DataContext.OpenFileFromTreeCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                          CommandParameter="{Binding}" />
                        </TextBlock.InputBindings>

                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                        <Setter Property="ContextMenu">
                                            <Setter.Value>
                                                <ContextMenu>
                                                    <MenuItem Header="New file" 
                                              Command="{Binding PlacementTarget.Tag.NewFileInFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>

                                                    <MenuItem Header="Copy path" 
                                              Command="{Binding PlacementTarget.Tag.CopyPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>

                                                    <MenuItem Header="Copy folder" 
                                              Command="{Binding PlacementTarget.Tag.CopyFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>

                                                    <MenuItem Header="Paste folder" 
                                              Command="{Binding PlacementTarget.Tag.PasteFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                </ContextMenu>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>

            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>

        <GridSplitter Grid.Row="2" Grid.Column="1" Width="5" 
                      HorizontalAlignment="Center" VerticalAlignment="Stretch" 
                      Background="LightGray"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Columns"
                      Visibility="{Binding IsFolderExplorerVisible, Converter={StaticResource BoolToVis}}" 
                      ShowsPreview="True" />

        <TabControl x:Name="MainTabControl"
            Grid.Row="2" Grid.Column="2" 
            ItemsSource="{Binding Documents}" 
            SelectedItem="{Binding SelectedDocument}">

            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ContentTemplate>
                <DataTemplate>
                    <TextBox AcceptsReturn="True" 
                             TextWrapping="Wrap" 
                             Text="{Binding TextContent, UpdateSourceTrigger=PropertyChanged}"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Stretch"
                             VerticalScrollBarVisibility="Auto" />
                </DataTemplate>
            </TabControl.ContentTemplate>

        </TabControl>
    </Grid>
</Window>
